<UserControl x:Class="cs464_project.View_Body.QuanLyKhachHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cs464_project.View_Body"
        xmlns:vm="clr-namespace:cs464_project.ViewModel"
        mc:Ignorable="d"
        Background="#F0F4F8"
        Loaded="Window_Loaded">
    <UserControl.DataContext>
        <vm:QuanLyKhachHangViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Rounded Button Template -->
        <ControlTemplate x:Key="RoundedButton" TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}"
                    CornerRadius="10" BorderThickness="0" Cursor="Hand">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#D8DEE9" BorderThickness="1"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Form Label Style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <!-- DataGrid Header Style -->
        <Style x:Key="ModernColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style x:Key="ModernCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Row Style -->
        <Style x:Key="ModernRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👥" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Quản Lý Khách Hàng" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Quản lý thông tin khách hàng của cửa hàng" FontSize="13" Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Search Bar Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16,12" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="txtTimKiem" Width="300"
                         Style="{StaticResource ModernTextBox}" Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                <Button x:Name="btnTimKiem" Content="Tìm kiếm" Command="{Binding SearchCommand}"
                        Width="110" Height="36" Margin="12,0,0,0"
                        Background="#0F62FE" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        Template="{StaticResource RoundedButton}"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid Card -->
            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="0" Margin="0,0,16,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                </Border.Effect>
                <DataGrid x:Name="dgKhachHang"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          HeadersVisibility="Column"
                          AlternationCount="2"
                          ColumnHeaderStyle="{StaticResource ModernColumnHeader}"
                          CellStyle="{StaticResource ModernCell}"
                          RowStyle="{StaticResource ModernRow}"
                          RowHeaderWidth="0"
                          Margin="0,8,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH" Binding="{Binding CustomerCode}" Width="90"/>
                        <DataGridTextColumn Header="Họ tên" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="SĐT" Binding="{Binding Phone}" Width="110"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                        <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Form Panel Card -->
            <Border Grid.Column="1" Background="White" CornerRadius="14" Padding="20,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Form Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Thông Tin Khách Hàng" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Height="1" Background="#E2E8F0" Margin="0,0,0,6"/>

                    <!-- Mã KH -->
                    <TextBlock Text="Mã KH" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtMaKH" IsReadOnly="True" Background="#EAECF0"
                             Style="{StaticResource ModernTextBox}" Text="{Binding MaKH, Mode=OneWay}"/>

                    <!-- Họ tên -->
                    <TextBlock Text="Họ tên" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtHoTen" Style="{StaticResource ModernTextBox}" Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- SĐT -->
                    <TextBlock Text="Số điện thoại" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtSDT" Style="{StaticResource ModernTextBox}" Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Email -->
                    <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Địa chỉ -->
                    <TextBlock Text="Địa chỉ" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="txtDiaChi" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             Style="{StaticResource ModernTextBox}"
                             VerticalContentAlignment="Top" Padding="10,8" Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Action Buttons -->
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button x:Name="btnThem" Content="✚ Thêm" Grid.Row="0" Grid.Column="0"
                                Height="36" Margin="0,0,4,8" Command="{Binding AddCommand}"
                                Background="#16A34A" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Template="{StaticResource RoundedButton}"/>
                        <Button x:Name="btnSua" Content="✏ Sửa" Grid.Row="0" Grid.Column="1"
                                Height="36" Margin="4,0,0,8" Command="{Binding EditCommand}"
                                Background="#0F62FE" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Template="{StaticResource RoundedButton}"/>
                        <Button x:Name="btnXoa" Content="🗑 Xóa" Grid.Row="1" Grid.Column="0"
                                Height="36" Margin="0,0,4,0" Command="{Binding DeleteCommand}"
                                Background="#DC2626" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Template="{StaticResource RoundedButton}"/>
                        <Button x:Name="btnLamMoi" Content="🔄 Làm mới" Grid.Row="1" Grid.Column="1"
                                Height="36" Margin="4,0,0,0" Command="{Binding RefreshCommand}"
                                Background="#6B7280" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Template="{StaticResource RoundedButton}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
