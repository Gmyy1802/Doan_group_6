<UserControl x:Class="cs464_project.View_Body.QuanLyHoaDon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cs464_project.View_Body"
        xmlns:vm="clr-namespace:cs464_project.ViewModel"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Background="#F0F4F8">
    <UserControl.DataContext>
        <vm:QuanLyHoaDonViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Card style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="#000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded TextBox style -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="#F8FAFC" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded ComboBox style -->
        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D8DEE9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Rounded DatePicker style -->
        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D8DEE9"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Rounded Button template -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid styles -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ModernColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FF"/>
                    <Setter Property="Foreground" Value="#1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Form label style -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24,28,20">
        <StackPanel>

            <!-- ══ HEADER ══ -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛒" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Quản Lý Hóa Đơn" FontSize="26" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Tạo, tìm kiếm và quản lý hóa đơn bán hàng" Foreground="#64748B" FontSize="13" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- ══ FILTER BAR ══ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <WrapPanel VerticalAlignment="Center">
                    <!-- Từ ngày -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="Từ ngày" Foreground="#475569" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker x:Name="dpTuNgay" Width="140" Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding TuNgay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Đến ngày -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="Đến ngày" Foreground="#475569" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker x:Name="dpDenNgay" Width="140" Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding DenNgay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Tìm kiếm -->
                    <TextBox x:Name="txtTimKiem" Width="220" Style="{StaticResource RoundedTextBox}"
                             Margin="0,0,12,0"
                             ToolTip="Tìm theo mã HĐ, tên khách hàng" Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Button tìm -->
                    <Button x:Name="btnTimKiem" Content="🔍  Tìm kiếm" Width="120"
                            Style="{StaticResource RoundedButton}" Background="#0F62FE"
                            Command="{Binding SearchCommand}"/>
                </WrapPanel>
            </Border>

            <!-- ══ MAIN CONTENT ══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Orders DataGrid -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="🧾" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Danh Sách Hóa Đơn" FontWeight="Bold" FontSize="15" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>

                        <DataGrid x:Name="dgOrders" Style="{StaticResource ModernDataGrid}"
                                  ItemsSource="{Binding Orders}"
                                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                                  CellStyle="{StaticResource ModernDataGridCell}"
                                  RowStyle="{StaticResource ModernDataGridRow}">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernColumnHeader}"/>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã HĐ" Binding="{Binding OrderCode}" Width="85"/>
                                <DataGridTextColumn Header="Ngày lập" Binding="{Binding OrderDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                                <DataGridTextColumn Header="Khách hàng" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TotalAmount, StringFormat=N0}" Width="110"/>
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="95"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- RIGHT: Create Order Form -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="-4,0,-4,0">
                        <StackPanel Margin="4,0,4,0">

                            <!-- Form Header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Width="40" Height="40" CornerRadius="10" Background="#EBF5FF" Margin="0,0,12,0">
                                    <TextBlock Text="📝" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Tạo Hóa Đơn Mới" FontWeight="Bold" FontSize="16" Foreground="#1E293B"/>
                                    <TextBlock Text="Điền thông tin để tạo hóa đơn" FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#E2E8F0" Margin="0,0,0,16"/>

                            <!-- Khách hàng -->
                            <TextBlock Text="KHÁCH HÀNG" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cboKhachHang" Style="{StaticResource RoundedComboBox}"
                                      ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                      DisplayMemberPath="FullName" SelectedValuePath="CustomerId" Margin="0,0,0,12"/>

                            <!-- Nhân viên -->
                            <TextBlock Text="NHÂN VIÊN" Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cboNhanVien" Style="{StaticResource RoundedComboBox}"
                                      ItemsSource="{Binding Employees}"
                                      SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                      DisplayMemberPath="FullName" SelectedValuePath="EmployeeId" Margin="0,0,0,16"/>

                            <!-- Thêm sản phẩm section -->
                            <Border Background="#F8FAFC" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="➕  Thêm sản phẩm" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B" Margin="0,0,0,10"/>

                                    <TextBlock Text="SẢN PHẨM" Style="{StaticResource FormLabel}"/>
                                    <ComboBox x:Name="cboSanPham" Style="{StaticResource RoundedComboBox}"
                                              ItemsSource="{Binding Products}"
                                              SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                              DisplayMemberPath="ProductName" SelectedValuePath="ProductId" Margin="0,0,0,10"
                                              Background="White"/>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="SỐ LƯỢNG" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="txtSoLuong" Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource RoundedTextBox}"/>
                                        </StackPanel>

                                        <Button x:Name="btnThemSP" Grid.Column="2" Content="＋ Thêm"
                                                Width="100" Style="{StaticResource RoundedButton}"
                                                Background="#0F62FE" Command="{Binding AddProductCommand}"
                                                VerticalAlignment="Bottom"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Order Items DataGrid -->
                            <DataGrid x:Name="dgOrderItems" Height="150"
                                      ItemsSource="{Binding OrderItems}"
                                      Style="{StaticResource ModernDataGrid}"
                                      CellStyle="{StaticResource ModernDataGridCell}"
                                      RowStyle="{StaticResource ModernDataGridRow}"
                                      Margin="0,0,0,12">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ModernColumnHeader}"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="SL" Binding="{Binding Quantity}" Width="50"/>
                                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, StringFormat=N0}" Width="90"/>
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding LineTotal, StringFormat=N0}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Tổng cộng -->
                            <Border Background="#FEF2F2" CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                                <TextBlock FontSize="15" HorizontalAlignment="Right">
                                    <Run Text="Tổng cộng:  " FontWeight="SemiBold" Foreground="#475569"/>
                                    <Run x:Name="runTongCong" Text="{Binding TongCong, StringFormat=N0}" FontWeight="Bold" Foreground="#DC2626" FontSize="18"/>
                                    <Run Text=" đ" FontWeight="Bold" Foreground="#DC2626" FontSize="18"/>
                                </TextBlock>
                            </Border>

                            <!-- Ghi chú -->
                            <TextBlock Text="GHI CHÚ" Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtGhiChu" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                     Margin="0,0,0,18" FontSize="13" Padding="10,8"
                                     VerticalContentAlignment="Top" Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="#F8FAFC" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>

                            <!-- Action Buttons -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnTaoHoaDon" Grid.Column="0"
                                        Content="✅  Tạo hóa đơn" Height="42"
                                        Style="{StaticResource RoundedButton}" Background="#16A34A"
                                        Command="{Binding CreateOrderCommand}"/>

                                <Button x:Name="btnHuyHoaDon" Grid.Column="2"
                                        Content="❌  Hủy hóa đơn" Height="42"
                                        Style="{StaticResource RoundedButton}" Background="#DC2626"
                                        Command="{Binding CancelOrderCommand}"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
